# ─── Copiez ce fichier en .env et remplissez les valeurs. NE COMMITEZ JAMAIS .env ───

# ===== n8n MCP (czlonkowski/n8n-mcp) =====
# URL de votre instance n8n (API REST). Ex local : http://localhost:5678
# Depuis une machine du réseau interne TargetUp : http(s)://<hote-n8n>:<port>
N8N_API_URL=https://votre-n8n.exemple.com
# Clé API n8n : Settings → n8n API → Create an API key
N8N_API_KEY=remplacez-moi

# ===== Odoo MCP (mcp-server-odoo / ivnvxd) =====
# URL de votre instance Odoo
ODOO_URL=https://votre-odoo.exemple.com
# Base de données Odoo (laisser vide si listing non restreint)
ODOO_DB=votre_base
# Clé API Odoo : Paramètres → Utilisateurs → (votre user) → onglet "Clés API"
ODOO_API_KEY=remplacez-moi
# Alternative à la clé API (déconseillé) :
# ODOO_USER=admin
# ODOO_PASSWORD=...
